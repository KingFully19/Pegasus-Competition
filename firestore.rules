rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users / trainee profiles ---
    match /users/{uid} {
      // Anyone signed in can read the roster (needed for the leaderboard).
      allow read: if signedIn();

      // A user may create ONLY their own profile, and only as a fresh,
      // unapproved trainee — prevents self-promoting to admin/approved.
      allow create: if signedIn() &&
        request.auth.uid == uid &&
        request.resource.data.uid == uid &&
        request.resource.data.role == 'trainee' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.totalPoints == 0;

      // Only the admin (Ohad) can approve, promote, award points, or delete.
      allow update, delete: if isAdmin();
    }

    // --- Missions / point-scoring criteria ---
    match /missions/{missionId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- Awards / point history ---
    match /awards/{awardId} {
      // A trainee can read their own award history; the admin can read all.
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
  }
}
